{
  "name": "@entur/mui-comps-nmr",
  "version": "0.0.0",
  "description": "MUI component library for Entur's hathor frontend — React, typed from the sobek GraphQL schema.",
  "license": "EUPL-1.2",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "codegen": "tsx scripts/fetchSchema.ts && graphql-codegen --config codegen.ts",
    "predistill": "npm run codegen",
    "distill": "tsx scripts/distillTypes.ts",
    "prebuild": "npm run distill",
    "build": "vite build",
    "prestorybook": "npm run distill",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "npm run distill",
    "build-storybook": "storybook build",
    "pretest": "npm run distill",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "npm run distill",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@mui/x-data-grid": "^8.29.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@mui/x-data-grid": "^8.29.1",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "graphql": "^16.11.0",
    "jsdom": "^26.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^10.0.0",
    "tsx": "^4.20.0",
    "typescript": "~5.8.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.0.0"
  }
}
